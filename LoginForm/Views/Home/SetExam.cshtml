@model LoginForm.Models.SetExamViewModel

@{
    ViewData["Title"] = "Set Exam Paper";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Set New Exam</title>
    <style>
        /* Greenish White Theme */
        :root {
            --bg-color: #f0fff4; /* Mint Cream */
            --card-bg: #ffffff;
            --primary-green: #38a169; /* Green 500 */
            --dark-green: #22543d;
            --border-color: #e2e8f0;
            --hover-row: #f0fff4;
        }

        body {
            background-color: var(--bg-color);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: #2d3748;
            padding: 2rem;
            display: flex;
            flex-direction: column; /* Stack containers vertically */
            align-items: center;    /* Center them */
            gap: 2rem;              /* Space between containers */
        }

        .container {
            width: 100%;
            max-width: 900px;
            background-color: var(--card-bg);
            padding: 2.5rem;
            border-radius: 12px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            border-top: 6px solid var(--primary-green);
        }

        h2 {
            color: var(--dark-green);
            margin-top: 0;
            margin-bottom: 1.5rem;
            border-bottom: 2px solid var(--bg-color);
            padding-bottom: 0.5rem;
        }

        /* Form Layout */
        .exam-details-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .form-group {
            margin-bottom: 1rem;
        }

        .form-group label {
            display: block;
            font-weight: 600;
            margin-bottom: 0.5rem;
            color: var(--dark-green);
        }

        .form-control {
            width: 100%;
            padding: 0.6rem;
            border: 1px solid var(--border-color);
            border-radius: 6px;
            box-sizing: border-box;
            font-size: 1rem;
        }

        .form-control:focus {
            outline: none;
            border-color: var(--primary-green);
            box-shadow: 0 0 0 3px rgba(56, 161, 105, 0.2);
        }

        textarea.form-control {
            resize: vertical;
            min-height: 80px;
        }

        /* Question Selection Table */
        .question-selection-area {
            border: 1px solid var(--border-color);
            border-radius: 8px;
            overflow: hidden;
        }

        .table-header {
            background-color: var(--primary-green);
            color: white;
            padding: 0.75rem 1rem;
            font-weight: bold;
            display: flex;
            justify-content: space-between;
        }

        .question-list {
            max-height: 400px; /* Scrollable area */
            overflow-y: auto;
        }

        .question-item {
            display: flex;
            align-items: center;
            padding: 0.75rem 1rem;
            border-bottom: 1px solid var(--border-color);
            transition: background 0.2s;
        }

        .question-item:hover {
            background-color: var(--hover-row);
        }

        .question-item:last-child {
            border-bottom: none;
        }

        .checkbox-wrapper {
            margin-right: 1rem;
            display: flex;
            align-items: center;
        }

        input[type="checkbox"] {
            width: 18px;
            height: 18px;
            cursor: pointer;
            accent-color: var(--primary-green);
        }

        .q-text { flex-grow: 1; font-size: 0.95rem; }
        .q-id { color: #718096; font-size: 0.8rem; margin-right: 1rem; width: 40px; font-weight: bold; }

        /* Buttons & Alerts */
        .actions {
            margin-top: 2rem;
            text-align: right;
        }

        .btn-save {
            background-color: var(--primary-green);
            color: white;
            padding: 0.75rem 2rem;
            border: none;
            border-radius: 6px;
            font-size: 1rem;
            font-weight: bold;
            cursor: pointer;
            transition: background 0.2s;
        }

        .btn-save:hover { background-color: #2f855a; }

        .validation-error { color: #e53e3e; font-size: 0.85em; margin-top: 0.25rem; display: block; }
        
        .alert-success { background-color: #c6f6d5; color: #22543d; padding: 1rem; border-radius: 6px; margin-bottom: 1rem; border: 1px solid #9ae6b4; }
        .alert-error { background-color: #fed7d7; color: #822727; padding: 1rem; border-radius: 6px; margin-bottom: 1rem; border: 1px solid #feb2b2; }
    </style>
</head>
<body>

    <div class="container">
        <h2>Set New Exam Paper</h2>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert-success">@TempData["SuccessMessage"]</div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert-error">@TempData["ErrorMessage"]</div>
        }

        <form asp-action="SetExam" method="post">
            <div class="exam-details-grid">
                <div class="form-group">
                    <label asp-for="Program">Select Program/Course</label>
                    <select asp-for="Program" class="form-control" required>
                        <option value="" disabled selected>-- Select Program --</option>
                        @foreach (var prog in Model.AvailablePrograms)
                        {
                            <option value="@prog">@prog</option>
                        }
                    </select>
                    <span asp-validation-for="Program" class="validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ExamDate">Exam Date</label>
                    <input asp-for="ExamDate" class="form-control" type="date" />
                    <span asp-validation-for="ExamDate" class="validation-error"></span>
                </div>
            </div>

            <h3>Select Questions</h3>
            <p style="color:#718096; font-size: 0.9em; margin-bottom: 1rem;">
                Check the boxes to include questions in this exam.
            </p>

            <div class="question-selection-area">
                <div class="table-header">
                    <span>Description</span>
                    <span>Select</span>
                </div>

                <div class="question-list">
                    @for (int i = 0; i < Model.AvailableQuestions.Count; i++)
                    {
                        <div class="question-item">
                            <div class="checkbox-wrapper">
                                <input type="checkbox" asp-for="AvailableQuestions[i].IsSelected" />
                                <input type="hidden" asp-for="AvailableQuestions[i].QuestionId" />
                                <input type="hidden" asp-for="AvailableQuestions[i].QuestionDescription" />
                            </div>

                            <div class="q-id">#@Model.AvailableQuestions[i].QuestionId</div>
                            <div class="q-text">@Model.AvailableQuestions[i].QuestionDescription</div>
                        </div>
                    }
                </div>
            </div>

            <div class="actions">
                <button type="submit" class="btn-save">Save Exam</button>
            </div>
        </form>
    </div>

    <div class="container">
        <h2>Add New Question to Database</h2>
        
        <form asp-action="AddQuestion" method="post">
            <div class="form-group">
                <label for="QuestionDescription">Question Description</label>
                <textarea id="QuestionDescription" name="QuestionDescription" class="form-control" placeholder="Enter the question text here..." required></textarea>
            </div>

            <div class="exam-details-grid">
                <div class="form-group">
                    <label for="OptionA">Option A</label>
                    <input type="text" id="OptionA" name="OptionA" class="form-control" required />
                </div>
                <div class="form-group">
                    <label for="OptionB">Option B</label>
                    <input type="text" id="OptionB" name="OptionB" class="form-control" required />
                </div>
                <div class="form-group">
                    <label for="OptionC">Option C</label>
                    <input type="text" id="OptionC" name="OptionC" class="form-control" required />
                </div>
                <div class="form-group">
                    <label for="OptionD">Option D</label>
                    <input type="text" id="OptionD" name="OptionD" class="form-control" required />
                </div>
            </div>

            <div class="form-group" style="max-width: 300px;">
                <label for="CorrectOption">Correct Option</label>
                <select id="CorrectOption" name="CorrectOption" class="form-control" required>
                    <option value="" disabled selected>-- Select Correct Answer --</option>
                    <option value="A">A</option>
                    <option value="B">B</option>
                    <option value="C">C</option>
                    <option value="D">D</option>
                </select>
            </div>

            <div class="actions">
                <button type="submit" class="btn-save" style="background-color: #2b6cb0;">+ Add Question</button>
            </div>
        </form>
    </div>

</body>
</html>
@model DashboardViewModel

@{
    ViewData["Title"] = "Special Admin Dashboard";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/admin-theme.css" />
    <style>
        .search-card {
            background-color: #ffffff;
            border-radius: 12px;
            padding: 1.5rem;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            border-left: 5px solid #38a169;
        }
        .search-input:focus {
            border-color: #38a169;
            box-shadow: 0 0 0 0.25rem rgba(56, 161, 105, 0.25);
        }
        .btn-search {
            background-color: #38a169;
            border-color: #38a169;
            color: white;
            font-weight: 600;
        }
        .btn-search:hover {
            background-color: #2f855a;
            border-color: #2f855a;
            color: white;
        }
    </style>
</head>
<body style="background-color: #f0fff4;">

    <header class="dashboard-header d-flex justify-content-between align-items-center p-3 bg-white shadow-sm mb-4">
        <div class="d-flex align-items-center">
            <i class="fas fa-university fa-2x text-success me-3"></i>
            <h2 class="dashboard-title m-0">Admin Dashboard</h2>
        </div>
        <a href="/Home/Index" class="btn btn-success btn-custom-green" style="background-color: #38a169; border: none;">
            <i class="fas fa-user-plus me-2"></i> Register New Student
        </a>
    </header>

    <div class="container">

        <div class="row mb-4">
            <div class="col-md-6 mb-3">
                <div class="stat-card bg-white p-3 rounded shadow-sm">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="stat-title text-muted">Total Registered Students</div>
                            <div class="stat-value fs-3 fw-bold">@Model.TotalStudents</div>
                        </div>
                        <i class="fas fa-users fa-3x text-success opacity-25"></i>
                    </div>
                </div>
            </div>

            <div class="col-md-6 mb-3">
                <div class="stat-card bg-white p-3 rounded shadow-sm">
                    <div class="stat-title mb-2 text-muted">Check Enrollment by Program</div>
                    <div class="d-flex align-items-center justify-content-between">
                        <select id="programSelect" class="form-select w-50 search-input">
                            @foreach (var prog in Model.ProgramCounts)
                            {
                                <option value="@prog.Key">@prog.Key</option>
                            }
                        </select>
                        <div class="text-end">
                            <div class="text-muted small">Enrolled</div>
                            <div class="stat-value fw-bold fs-4" id="programCountDisplay">0</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-md-6">
                <a href="/Home/GenerateAdmitCard" class="btn btn-outline-success w-100 py-3 shadow-sm" style="color: #38a169; border-color: #38a169;">
                    <i class="fas fa-file-invoice fa-lg me-2"></i> Generate Admit Card
                </a>
            </div>
            <div class="col-md-6">
                <a href="/Home/SetExam" class="btn btn-outline-success w-100 py-3 shadow-sm" style="color: #38a169; border-color: #38a169;">
                    <i class="fas fa-file-pen fa-lg me-2"></i> Create Exam Questions 
                </a>
            </div>
        </div>

        <div class="row mb-5">
            <div class="col-12">
                <div class="search-card">
                    <h5 class="text-success mb-3" style="color: #22543d !important;">
                        <i class="fas fa-search me-2"></i> View Student Profile
                    </h5>
                    @if (TempData["SearchError"] != null)
                    {
                        <div class="alert alert-danger py-2">@TempData["SearchError"]</div>
                    }
                    <form action="/Home/StudentDetails" method="get" class="d-flex align-items-center gap-3">
                        <input type="email" name="email" class="form-control search-input" placeholder="Enter registered student email..." required>
                        <button type="submit" class="btn btn-search px-4 py-2 text-nowrap">
                            <i class="fas fa-id-card me-2"></i> View Record
                        </button>
                    </form>
                </div>
            </div>
        </div>
        <div class="row mb-5">
            <div class="col-12">
                <div class="search-card">
                    <h5 class="text-success mb-3" style="color: #22543d !important;">
                        <i class="fas fa-poll me-2"></i> View Student Results
                    </h5>
                    
                    @if (TempData["ResultSearchError"] != null)
                    {
                        <div class="alert alert-danger py-2">@TempData["ResultSearchError"]</div>
                    }
                    
                    <form action="/Home/AdminDashboard" method="get" class="d-flex align-items-center gap-3 mb-4">
                        <input type="email" name="resultEmail" class="form-control search-input" 
                               placeholder="Enter student email to fetch results..." 
                               value="@Model.SearchedResultEmail" required>
                        <button type="submit" class="btn btn-search px-4 py-2 text-nowrap">
                            <i class="fas fa-table me-2"></i> Fetch Results
                        </button>
                    </form>

                    @if (Model.SearchedResults != null)
                    {
                        if (!Model.SearchedResults.Any())
                        {
                            <div class="alert alert-light text-center border mt-3">
                                <i class="fas fa-inbox fa-2x text-muted mb-2"></i>
                                <p class="m-0 text-muted">No examination results found for <strong>@Model.SearchedResultEmail</strong>.</p>
                            </div>
                        }
                        else
                        {
                            <div class="table-responsive mt-3 border rounded">
                                <table class="table table-hover mb-0">
                                    <thead style="background-color: #f0fff4; color: #22543d;">
                                        <tr>
                                            <th class="p-3">Exam ID</th>
                                            <th class="p-3">Total Questions</th>
                                            <th class="p-3">Correct Answers</th>
                                            <th class="p-3">Score</th>
                                            <th class="p-3">Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var result in Model.SearchedResults)
                                        {
                                            double percentage = result.TotalQuestion > 0 
                                                ? Math.Round(((double)result.CorrectlyAnswered / result.TotalQuestion) * 100, 1) 
                                                : 0;
                                            <tr>
                                                <td class="p-3 fw-bold text-muted">#@result.ExamId</td>
                                                <td class="p-3">@result.TotalQuestion</td>
                                                <td class="p-3">@result.CorrectlyAnswered</td>
                                                <td class="p-3"><strong>@percentage%</strong></td>
                                                <td class="p-3">
                                                    @if (result.IsPassed)
                                                    {
                                                        <span style="color: #38a169; font-weight: bold;"><i class="fas fa-check-circle me-1"></i> Passed</span>
                                                    }
                                                    else
                                                    {
                                                        <span style="color: #e53e3e; font-weight: bold;"><i class="fas fa-times-circle me-1"></i> Failed</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-12">
                <div class="chart-container bg-white p-4 rounded shadow-sm">
                    <h4 class="text-success mb-4" style="color: #22543d !important;">Enrollment Overview</h4>
                    <canvas id="studentsBarChart" height="100"></canvas>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        var dbProgramData = @Html.Raw(Json.Serialize(Model.ProgramCounts));
    </script>
    <script src="~/js/admin-logic.js"></script>
</body>
</html>